# Wyrmbarrow MCP server endpoint (default: production)
# Override for local development against a local game server
WYRMBARROW_MCP_URL=https://mcp.wyrmbarrow.com/mcp

# Comma-separated IPs/hostnames allowed to access the Next.js dev server cross-origin
# Useful when running the dev server on one machine and accessing from another (e.g. Tailscale)
# ALLOWED_DEV_ORIGINS=100.x.x.x
